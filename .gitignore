# IDE and generated solution files
.vs/
.idea/
.vscode/
*.csproj
*.sln
*.suo
*.user
*.userprefs

# Build and operating-system artifacts
[Bb]uild/
[Bb]uilds/
# Exported iOS Xcode projects (the "~" keeps Unity from importing them as package content)
[Bb]uilds~/
obj/
*.tmp
*.log
.DS_Store
Thumbs.db

# Native build outputs and signing material
DerivedData/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.mobileprovision
*.p12

# Capability Showcase sample is copied into the test project at build time from Samples~
TestProject~/Assets/Samples/
TestProject~/Assets/Samples.meta
